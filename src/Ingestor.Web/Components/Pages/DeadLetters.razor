@page "/dead-letters"
@inject IngestorApiClient Api
@implements IDisposable

<PageTitle>Dead Letters — Ingestor</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="mb-0 fw-semibold">Dead Letters</h4>
    @if (_lastUpdated.HasValue)
    {
        <small class="text-muted">
            <i class="bi bi-arrow-repeat me-1"></i>Updated @_lastUpdated.Value.ToLocalTime().ToString("HH:mm:ss")
        </small>
    }
</div>

@if (_loadError is not null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@_loadError
    </div>
}
else if (_jobs is null)
{
    <div class="text-center text-muted py-5">
        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
    </div>
}
else if (_jobs.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-check-circle display-4 text-success d-block mb-3"></i>
            No dead-lettered jobs. All clear.
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-semibold small">
            <i class="bi bi-exclamation-triangle me-2 text-danger"></i>
            @_jobs.Count dead-lettered job@(_jobs.Count == 1 ? "" : "s")
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3" style="width:120px">ID</th>
                        <th>Supplier</th>
                        <th>Type</th>
                        <th>Received</th>
                        <th>Last Error</th>
                        <th class="pe-3 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in _jobs)
                    {
                        var state = GetRowState(job.Id);
                        <tr>
                            <td class="ps-3 font-monospace text-muted small align-middle">
                                <a href="/imports/@job.Id" class="text-decoration-none text-muted">
                                    @job.Id.ToString()[..8]…
                                </a>
                            </td>
                            <td class="align-middle">@job.SupplierCode</td>
                            <td class="align-middle small text-muted">@job.ImportType</td>
                            <td class="align-middle small text-muted">
                                @job.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                            </td>
                            <td class="align-middle small">
                                @if (state.Error is not null)
                                {
                                    <span class="text-danger">@state.Error</span>
                                }
                                else if (state.Requeued)
                                {
                                    <span class="text-success">
                                        <i class="bi bi-check-circle me-1"></i>Requeued
                                    </span>
                                }
                            </td>
                            <td class="pe-3 text-end align-middle">
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => RequeueAsync(job.Id)"
                                        disabled="@(state.Loading || state.Requeued)">
                                    @if (state.Loading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                                    }
                                    Requeue
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<ImportJobResponse>? _jobs;
    private string? _loadError;
    private DateTimeOffset? _lastUpdated;

    private readonly Dictionary<Guid, RowState> _rowStates = new();
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _ = PollAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var page = await Api.GetJobsAsync(status: "DeadLettered", ct: _cts.Token);
            if (page is not null)
            {
                _jobs = [..page.Items];
                _lastUpdated = DateTimeOffset.UtcNow;
                _loadError = null;
            }
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _loadError = $"Could not reach API: {ex.Message}";
        }
    }

    private async Task RequeueAsync(Guid jobId)
    {
        _rowStates[jobId] = new RowState(Loading: true);

        try
        {
            var (success, error) = await Api.RequeueAsync(jobId, _cts.Token);
            _rowStates[jobId] = success
                ? new RowState(Requeued: true)
                : new RowState(Error: error ?? "Requeue failed");
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _rowStates[jobId] = new RowState(Error: ex.Message);
        }
    }

    private async Task PollAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private RowState GetRowState(Guid id) =>
        _rowStates.TryGetValue(id, out var s) ? s : new RowState();

    public void Dispose() => _cts.Cancel();

    private sealed record RowState(
        bool Loading = false,
        bool Requeued = false,
        string? Error = null);
}
